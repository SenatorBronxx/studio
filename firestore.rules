
/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for the Eritas Gateway
 * application. All user-related data is private.
 *
 * Data Structure:
 * - /users/{userId}: Stores public-facing user profile information.
 * - /users/{userId}/preferences/{prefsId}: Stores private user settings.
 * - /trips/{tripId}: Stores trip documents, shared between user and driver.
 * - /buses/{busId}: Stores live data for active buses, broadcast by drivers.
 * - /drivers/{driverId}: Stores driver profile information.
 * - /drivers/{driverId}/earnings/{earningId}: Stores driver earnings records.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Returns true if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the requesting user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isOwner(userId);
      allow list: if false; // No one can list all users

      /**
       * @description Manages a single document of user preferences.
       * @path /users/{userId}/preferences/{prefsId}
       */
      match /preferences/{prefsId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    /**
     * @description Manages trip documents, shared between users and drivers.
     * @path /trips/{tripId}
     */
    match /trips/{tripId} {
      // Let any signed-in user read/write trips for now.
      allow read, write: if isSignedIn();
    }

    /**
     * @description Manages live bus data broadcasted by driver apps.
     * @path /buses/{busId}
     */
    match /buses/{busId} {
      // Any signed-in user can see active buses.
      allow read, write: if isSignedIn();
    }
    
    /**
     * @description Manages driver profile documents.
     * @path /drivers/{driverId}
     */
    match /drivers/{driverId} {
      allow read, update, delete: if isOwner(driverId);
      allow create: if isOwner(driverId);
      allow list: if false;

      /**
       * @description Manages driver earnings records.
       * @path /drivers/{driverId}/earnings/{earningId}
       */
      match /earnings/{earningId} {
        // Only the driver can read their own earnings.
        // Earnings records are created by a secure backend process, not directly by the driver app.
        allow read: if isOwner(driverId);
        allow write: if false; // Prevent driver app from writing/tampering with earnings.
      }
    }
  }
}

    