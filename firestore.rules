/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model. All data is scoped
 * directly to the authenticated user, ensuring that a user can only ever access their own
 * information. This is the most secure posture for applications handling private user data.
 *
 * Data Structure: All data is organized under the top-level `/users` collection. Each user's
 * data is stored in a document where the document ID is the user's Firebase Authentication UID
 * (e.g., `/users/{userId}`). This path-based ownership is simple, performant, and highly secure.
 *
 * Key Security Decisions:
 * - User Isolation: A user can only read, write, and delete their own document within the `/users`
 *   collection. Access to other users' data is strictly prohibited.
 * - No User Enumeration: Listing the entire `/users` collection is disallowed to prevent
 *   malicious actors from discovering the application's user base.
 * - Self-Service Profile Creation: A newly authenticated user is permitted to create their own
 *   initial user profile document.
 *
 * Denormalization for Authorization: This model uses the document ID (`userId`) as the sole
 * source of truth for ownership, which is the most efficient form of authorization. This avoids
 * costly `get()` calls to other documents, as all necessary information is present in the path.
 *
 * Structural Segregation: Not applicable in this simple model, as all data is private user data.
 * If public data were introduced, it would be stored in a separate top-level collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // --- Helper Functions
    // ------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the requesting user's UID matches the document's ID from the path.
     * This is the primary function for enforcing user ownership.
     * @param userId The document ID, corresponding to a user's UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for safe updates and deletes.
     * Denies requests that target documents which do not exist.
     * @param userId The document ID, corresponding to a user's UID.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // ------------------------------------------------------------------------
    // --- Validation Functions (Prototyping Mode)
    // ------------------------------------------------------------------------

    /**
     * Validates critical fields during user profile creation.
     * Ensures the internal 'id' field matches the user's auth UID for relational integrity.
     * @param userId The user's UID from the path.
     */
    function hasValidCreationData(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * Validates critical fields during a user profile update.
     * Enforces immutability of the 'id' field to prevent re-assigning ownership.
     */
    function hasValidUpdateData() {
      // The internal 'id' field must never be changed after creation.
      return request.resource.data.id == resource.data.id;
    }


    // ------------------------------------------------------------------------
    // --- Collection: users
    // ------------------------------------------------------------------------

    /**
     * @description Controls access to a user's own profile document.
     * @path /users/{userId}
     * @allow (get) A signed-in user (`uid: "user_abc"`) can get their own document at `/users/user_abc`.
     * @allow (create) A new user (`uid: "user_abc"`) can create their profile at `/users/user_abc` if the document includes `{"id": "user_abc"}`.
     * @deny (list) A user cannot list the entire `/users` collection to prevent user enumeration.
     * @deny (update) A user (`uid: "user_abc"`) cannot update another user's document at `/users/user_xyz`.
     * @principle Restricts access to a user's own data tree and enforces relational integrity between the Auth UID and the document data.
     */
    match /users/{userId} {
      // READ: A user can only get their own profile.
      allow get: if isOwner(userId);

      // LIST: Listing the users collection is denied for security and privacy.
      allow list: if false;

      // CREATE: A user can create their own profile document, ensuring the internal `id` is set correctly.
      allow create: if isOwner(userId) && hasValidCreationData(userId);

      // UPDATE: The owner can update their profile, but cannot change the immutable `id` field.
      allow update: if isExistingOwner(userId) && hasValidUpdateData();

      // DELETE: The owner can delete their own profile document.
      allow delete: if isExistingOwner(userId);
    }
  }
}