
/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for the Eritas Gateway
 * application. All user-related data is private.
 *
 * Data Structure:
 * - /users/{userId}: Stores public-facing user profile information.
 * - /users/{userId}/preferences/{prefsId}: Stores private user settings.
 * - /trips/{tripId}: Stores trip documents, shared between user and driver.
 * - /buses/{busId}: Stores live data for active buses, broadcast by drivers.
 * - /drivers/{driverId}: Stores private driver information.
 * - /registrationCodes/{codeId}: Stores one-time codes for driver registration.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Returns true if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the requesting user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the user is an admin.
     * Admins have elevated privileges.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    /**
     * Returns true if the user is a driver.
     */
    function isDriver() {
        return isSignedIn() && request.auth.token.driver == true;
    }


    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     */
    match /users/{userId} {
      // Admins can read/write any user document. Users can only manage their own.
      allow read, update, delete: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId); // Users create their own doc on signup.
      allow list: if isAdmin(); // Only admins can list all users.

      /**
       * @description Manages a single document of user preferences.
       * @path /users/{userId}/preferences/{prefsId}
       */
      match /preferences/{prefsId} {
        // Admins can manage preferences, users can only manage their own.
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    /**
     * @description Manages trip documents, shared between users and drivers.
     * @path /trips/{tripId}
     */
    match /trips/{tripId} {
      // Let any signed-in user read/write trips for now.
      allow read, write: if isSignedIn();
    }

    /**
     * @description Manages live bus data broadcasted by driver apps.
     * @path /buses/{busId}
     */
    match /buses/{busId} {
      // Any signed-in user can see active buses.
      // Only drivers or admins can update bus information.
      allow read: if isSignedIn();
      allow write: if isDriver() || isAdmin();
    }

    /**
     * @description Manages private driver data.
     * @path /drivers/{driverId}
     */
    match /drivers/{driverId} {
        // Only admins can create, read, or modify driver profiles.
        // A driver can read their own profile.
        allow read: if isAdmin() || isOwner(driverId);
        allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description Manages one-time registration codes for drivers.
     * @path /registrationCodes/{codeId}
     */
    match /registrationCodes/{codeId} {
        // Only admins can create or read codes.
        // Any signed-in user can attempt to 'claim' (update) a code.
        allow get, list, create, delete: if isAdmin();
        allow update: if isSignedIn();
    }
  }
}
