/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for the Eritas Gateway
 * application. All user-related data is private, and a user can only access
 * their own information. This creates a secure, multi-tenant environment where
 * user data is completely isolated.
 *
 * Data Structure:
 * The data model is straightforward, with a single top-level collection `/users`.
 * Each document within this collection, identified by a user's unique ID (`userId`),
 * contains that user's profile information.
 * - /users/{userId} -> User Profile Document
 *
 * Key Security Decisions:
 * - User Isolation: The primary security guarantee is that an authenticated user
 *   can only ever read or write their own document at `/users/{their_own_userId}`.
 * - No User Listing: To protect user privacy and prevent data scraping, it is
 *   impossible for any client to list all documents in the `/users` collection.
 * - Document Integrity: On creation, the `id` field within a user document must
 *   match the `userId` in the document path, ensuring a consistent link between
 *   the document's identity and its location. This ID is immutable.
 * - Default Deny: All operations are denied by default and only explicitly
 *   allowed by the rules defined below.
 *
 * Denormalization for Authorization:
 * This ruleset does not require complex denormalization as the data model is
 * simple. The `userId` in the document path serves as the sole authorization key.
 *
 * Structural Segregation:
 * Not applicable in this simple model, as all user data is considered private
 * and there is no public/private distinction.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Returns true if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the requesting user's UID matches the provided userId.
     * This is the core function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the document already exists and the requesting user
     * is the owner. Used for safe updates and deletes.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }


    /**
     * On create, validates that the document's internal 'id' field matches
     * the document's ID in the path ({userId}). This enforces relational
     * integrity from the start.
     */
    function hasValidUserIdOnCreate(userId) {
      return request.resource.data.id == userId;
    }

    /**
     * On update, ensures the document's internal 'id' field cannot be changed.
     * This makes the core ownership link immutable.
     */
    function isUserIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     * @allow (create) An authenticated user can create their own user document.
     * @deny (get) An authenticated user cannot read another user's document.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && hasValidUserIdOnCreate(userId);
      allow update: if isExistingOwner(userId) && isUserIdImmutable();
      allow delete: if isExistingOwner(userId);
    }
  }
}