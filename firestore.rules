
/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for the Eritas Gateway
 * application. All user-related data is private, and a user can only access
 * their own information. A separate 'trips' collection facilitates communication
 * between the user and driver apps with specific field-level access control.
 * Admins have broader permissions for management purposes.
 *
 * Data Structure:
 * - /users/{userId}: Stores public-facing user profile information.
 * - /users/{userId}/preferences/{prefsId}: Stores private user settings.
 * - /drivers/{driverId}: Stores permanent driver and assigned bus information.
 * - /trips/{tripId}: Stores trip documents, shared between user and driver.
 * - /buses/{busId}: Stores live data for active buses, broadcast by drivers.
 * - /registrationCodes/{codeId}: Stores one-time use codes for driver registration.
 *
 * Key Security Decisions:
 * - User Isolation: A user can only read/write their own documents in their
 *   own data tree (`/users/{their_own_userId}`).
 * - Driver Data: A driver can read their own permanent record. No one can
 *   write to it from the client-side to prevent tampering.
 * - Trip Ownership: A user can create a trip for themselves and read a trip
 *   if their userId matches the trip's userId. They cannot see other users' trips.
 * - Driver Permissions: A user with a `driver: true` custom claim can read
 *   any trip and update specific fields like `status` and `currentBusLocation`.
 *   They cannot create or delete trips via the app.
 * - Public Bus Data: All signed-in users can read the list of active buses to
 *   use the app's core functionality. Only drivers can update bus data.
 * - Registration Codes: Codes can only be written by a trusted backend process (not client apps).
 *   They can be read by any signed-in user to allow for validation during signup.
 * - Admin Permissions: Users with an `admin: true` custom claim have read access to
 *   most data for oversight and write access to collections like /drivers for management.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Returns true if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the requesting user's UID matches the provided userId.
     * This is the core function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Returns true if the user is a designated driver.
     * This relies on a custom claim set by a backend admin process.
     */
    function isDriver() {
        return isSignedIn() && request.auth.token.driver == true;
    }

    /**
     * Returns true if the user is a designated admin.
     * This relies on a custom claim set by a backend admin process.
     */
    function isAdmin() {
        return isSignedIn() && request.auth.token.admin == true;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admins can list all users

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) || isAdmin();

      /**
       * @description Manages a single document of user preferences.
       * @path /users/{userId}/preferences/{prefsId}
       */
      match /preferences/{prefsId} {
        // Only the owner of the parent user document can access preferences.
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    /**
     * @description Stores permanent driver and assigned bus information.
     * @path /drivers/{driverId}
     */
    match /drivers/{driverId} {
      // A driver can read their own record. An admin can read any driver record.
      allow get: if isOwner(driverId) || isAdmin();
      // Admins can list all drivers.
      allow list: if isAdmin();
      // Client-side apps cannot update or delete these records to prevent tampering.
      // Only an admin (via a trusted process/app) can create driver records.
      allow create, update: if isAdmin();
      allow delete: if false; // Deletions should be handled by a backend process
    }

    /**
     * @description Manages trip documents, shared between users and drivers.
     * @path /trips/{tripId}
     */
    match /trips/{tripId} {
      // A user can read a trip if they booked it. A driver or admin can read any trip.
      allow get: if isSignedIn() && (isOwner(resource.data.userId) || isDriver() || isAdmin());
      
      // Admins can list all trips.
      allow list: if isAdmin();

      // A user can create a trip, but only for themselves.
      allow create: if isOwner(request.resource.data.userId);

      // A driver or admin can update specific fields. A user can update fields if they are the owner.
      allow update: if isDriver() || isOwner(resource.data.userId) || isAdmin();

      // Trips are "cancelled" (status update), not deleted by clients.
      allow delete: if false; 
    }

    /**
     * @description Manages live bus data broadcasted by driver apps.
     * @path /buses/{busId}
     */
    match /buses/{busId} {
      // Any signed-in user can see the list of active buses.
      allow read: if isSignedIn();
      
      // Only authenticated drivers should be able to create or update their bus document. Admins can also write.
      allow write: if isDriver() || isAdmin();
    }
    
    /**
     * @description Stores one-time codes for driver registration.
     * @path /registrationCodes/{codeId}
     */
    match /registrationCodes/{codeId} {
        // Any signed-in user can read a code to validate it during signup.
        allow read: if isSignedIn();
        // Only a trusted backend process can create or update codes.
        allow write: if false;
    }
  }
}
