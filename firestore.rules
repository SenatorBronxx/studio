
/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for the Eritas Gateway
 * application. All user-related data is private, and a user can only access
 * their own information. This creates a secure, multi-tenant environment where
 * user data is completely isolated.
 *
 * Data Structure:
 * - /users/{userId}: Stores public-facing user profile information.
 * - /users/{userId}/preferences/{prefsId}: Stores a single document with a
 *   well-known ID containing all private user settings, wallet info, etc.
 *
 * Key Security Decisions:
 * - User Isolation: A user can only read/write their own documents in their
 *   own data tree (`/users/{their_own_userId}`).
 * - No User Listing: It is impossible for any client to list all users.
 * - Document Integrity: The `id` field in a user document must match the
 *   `userId` in the path, and it is immutable.
 * - Preferences Ownership: Access to the preferences subcollection is strictly
 *   limited to the owner of the parent user document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Returns true if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the requesting user's UID matches the provided userId.
     * This is the core function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Prevent listing all users

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);

      /**
       * @description Manages a single document of user preferences.
       * @path /users/{userId}/preferences/{prefsId}
       */
      match /preferences/{prefsId} {
        // Only the owner of the parent user document can access preferences.
        allow read, write: if isOwner(userId);
      }
    }
  }
}
