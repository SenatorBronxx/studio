
/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for the Eritas Gateway
 * application. All user-related data is private.
 *
 * Data Structure:
 * - /users/{userId}: Stores public-facing user profile information.
 * - /users/{userId}/preferences/{prefsId}: Stores private user settings.
 * - /trips/{tripId}: Stores trip documents, shared between user and driver.
 * - /buses/{busId}: Stores live data for active buses, broadcast by drivers.
 * - /drivers/{driverId}: Stores public driver profiles.
 * - /registrationCodes/{code}: Stores one-time registration codes for drivers.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Returns true if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the requesting user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the user has the 'driver' custom claim.
     */
    function isDriver() {
      return isSignedIn() && request.auth.token.driver == true;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);

      /**
       * @description Manages a single document of user preferences.
       * @path /users/{userId}/preferences/{prefsId}
       */
      match /preferences/{prefsId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    /**
     * @description Manages trip documents, shared between users and drivers.
     * @path /trips/{tripId}
     */
    match /trips/{tripId} {
      // For now, let any signed-in user read/write trips.
      // In a real app, this would be restricted to the user who booked it or the driver.
      allow read, write: if isSignedIn();
    }

    /**
     * @description Manages live bus data broadcasted by driver apps.
     * @path /buses/{busId}
     */
    match /buses/{busId} {
      // Any signed in user can see active buses.
      // For development, allow any signed-in user to write.
      allow read, write: if isSignedIn();
    }

    /**
     * @description Manages driver profile documents.
     * @path /drivers/{driverId}
     */
    match /drivers/{driverId} {
      // For development, allow any signed-in user to read/write driver profiles.
      allow read, write: if isSignedIn();
    }

    /**
     * @description Manages one-time registration codes for drivers.
     * @path /registrationCodes/{code}
     */
    match /registrationCodes/{code} {
      // Any authenticated user can read a code to check its validity.
      allow get: if isSignedIn();
      allow list: if false;
      // Only an admin can create codes (for now, allow any signed-in user for testing).
      allow create: if isSignedIn();
      // Once a code exists, only a signed-in user can update it (to redeem it).
      allow update: if isSignedIn();
      allow delete: if false;
    }
  }
}
