
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Eritas Gateway application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user entity."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "signUpDate": {
          "type": "string",
          "description": "The date and time when the user signed up.",
          "format": "date-time"
        },
        "lastLogin": {
          "type": "string",
          "description": "The date and time when the user last logged in.",
          "format": "date-time"
        },
        "profilePicture": {
          "type": "string",
          "description": "URL of the user's profile picture.",
          "format": "uri"
        },
        "googleId": {
          "type": "string",
          "description": "Google identifier for users who signed up using Google."
        }
      },
      "required": [
        "id",
        "email",
        "firstName",
        "lastName",
        "signUpDate"
      ]
    },
    "UserPreferences": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User Preferences",
      "type": "object",
      "description": "Stores all user-specific settings, preferences, and data.",
      "properties": {
        "id": { "type": "string" },
        "language": { "type": "string", "default": "en-us" },
        "walletBalance": { "type": "number" },
        "loyaltyPoints": { "type": "number" },
        "transactions": { "type": "array", "items": { "$ref": "#/entities/Transaction" } },
        "savedSongs": { "type": "array", "items": { "$ref": "#/entities/Track" } },
        "activeDiscount": { "type": ["object", "null"], "properties": {
            "code": { "type": "string" },
            "percentage": { "type": "number" },
            "description": { "type": "string" }
        }},
        "isDiscountBannerDismissed": { "type": "boolean" },
        "notificationSettings": {
          "type": "object",
          "properties": {
            "routeAlerts": { "type": "boolean" },
            "bookingAlerts": { "type": "boolean" },
            "systemAlerts": { "type": "boolean" }
          }
        },
        "securitySettings": {
          "type": "object",
          "properties": {
            "isPinEnabled": { "type": "boolean" },
            "isBiometricEnabled": { "type": "boolean" },
            "is2faEnabled": { "type": "boolean" }
          }
        },
        "savedPlaces": { "type": "array", "items": { "$ref": "#/entities/SavedPlace" } }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["payment", "top-up"] },
        "plate": { "type": "string" },
        "amount": { "type": "number" }
      }
    },
    "Track": {
      "title": "Track",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "image": { "type": "string" },
        "duration": { "type": "string" }
      }
    },
    "SavedPlace": {
      "title": "Saved Place",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["home", "work", "other"] },
        "address": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "user",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profile information. Path-based ownership is enforced, allowing each user to only access their own document.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/preferences/{prefsId}",
        "definition": {
          "entityName": "userPreferences",
          "schema": {
            "$ref": "#/backend/entities/UserPreferences"
          },
          "description": "Stores a single document containing all preferences for a user.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            },
            {
              "name": "prefsId",
              "description": "The unique identifier of the preferences document."
            }
          ]
        }
      }
    ],
    "reasoning": "This Firestore data structure is designed for the Eritas Gateway bus booking application. It prioritizes security and scalability following the core design principles of Authorization Independence, Clarity of Intent, DBAC (Database-Based Access Control), and QAPs (Rules are not Filters). User data is stored in a dedicated collection, ensuring clear ownership and simplified security rules. A subcollection for user preferences is used to group all user-specific settings, making data management and access control straightforward."
  }
}
